QWEN_API_KEY=your-api-key-here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-plus
QWEN_OUTLINE_MODEL=qwen3.6-plus
QWEN_ENABLE_THINKING=false
# Lower temperature/top_p for more stable extraction (same page re-run varies less)
QWEN_TEMPERATURE=0
QWEN_TOP_P=0.1
QWEN_MAX_TOKENS=8192
# Optional fixed seed when the model supports it; leave empty to omit
# QWEN_SEED=42
PDF_RENDER_DPI=600
MAX_PREVIOUS_TAIL_CHARS=300
PYMUPDF_TEXT_MIN_CHARS=50
PYMUPDF_STRUCTURE_CONFIDENCE_MIN=0.45
PHASE2_MAX_WORKERS=16
REPAIR_TAIL_CONTINUATIONS=false
